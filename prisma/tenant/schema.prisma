generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@prisma/tenant-client"
}

datasource db {
  provider = "postgresql"
}

enum StatusType {
  success
  failed
}

enum ExportTypeEnum {
  csv_stats
  csv_empower
}

model Call {
  call_id     String    @id @db.VarChar(255)
  date_start  DateTime?
  date_answer DateTime?
  user_id     String?   @db.VarChar(45)
  user_name   String?   @db.VarChar(45)
  direction   String?   @db.VarChar(20)
  duration    Int?
  from_number String?   @db.VarChar(25)
  to_number   String?   @db.VarChar(25)
  is_answered Boolean?
  last_state  String?   @db.VarChar(25)
  tags        Json?
  raw_data    Json?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  historique_lecture_id   Int?
  id          String?
  ChannelID   String?  @db.VarChar(45)
  type        String?  @db.VarChar(45)
  HangupTime  DateTime?
  InCallDuration  Decimal?  @db.Decimal(20, 2)
  QueueDuration   Decimal?  @db.Decimal(20, 6)
  HoldDuration    Decimal?  @db.Decimal(20, 6)
  RingingDuration Decimal?  @db.Decimal(20, 6)
  AfterCallDuration Decimal?  @db.Decimal(20, 6)
  IVRDuration       Decimal? @db.Decimal(20, 6)
  contact String?
  IVRID  String? 
  ScenarioName String?
  File String? @db.VarChar(255)
  Note String?  @db.VarChar(255)
  Tags String? @db.VarChar(120)
  HangupBy  String? @db.VarChar(45)
  Groups String? @db.VarChar(45)
  Notes  String? @db.VarChar(150)
  Locations String? @db.VarChar(255)
  DigitEntered  String? @db.VarChar(255)
  Missed  DateTime?

  @@map("call")
}

model EmpowerStats {
  empower_id    Int       @id @default(autoincrement())
  call_uuid     String?   @db.VarChar(255)
  call_id       String?   @db.VarChar(255) @unique
  score_global  Float?
  customer_sentiment     String?   @db.VarChar(255)
  moments       Json?
  transcription String?   @db.Text
  raw_data      Json?
  created_at    DateTime?

  @@map("empower_stats")
}

model Export {
  id                      Int            @id @default(autoincrement())
  export_type             ExportTypeEnum
  file_path               String         @db.Text
  status                  StatusType     @default(failed)
  error_message           String?        @db.Text
  created_at              DateTime?      @default(now())
  updated_at              DateTime?      @updatedAt
  historique_lecture_id   Int 

  @@map("exports")
}
